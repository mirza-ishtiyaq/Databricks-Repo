{
  "datasets": [
    {
      "name": "b275db27",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT \n",
        "    latitude,\n",
        "    longitude,\n",
        "    `GHG emissions mtons CO2e`as emissions\n",
        "FROM emissions_data;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "e890cbb2",
      "displayName": "Emissions Per Persion",
      "queryLines": [
        "SELECT \n",
        "    county_state_name,\n",
        "    population,\n",
        "    CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS double) / population AS emissions_per_person\n",
        "FROM emissions_data\n",
        "ORDER BY emissions_per_person DESC;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "e3030142",
      "displayName": "Total Emissions per State",
      "queryLines": [
        "SELECT \n",
        "    state_abbr,\n",
        "    sum(CAST(\n",
        "        REPLACE(\n",
        "            `GHG emissions mtons CO2e`, ',', '') AS double\n",
        "            )) AS Total_emissions\n",
        "FROM emissions_data\n",
        "GROUP BY state_abbr\n",
        "ORDER BY Total_emissions DESC\n",
        "LIMIT 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "d42ad569",
      "displayName": "County shaming",
      "queryLines": [
        "SELECT\n",
        "    county_state_name,\n",
        "    population,\n",
        "    cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) as Total_emissions\n",
        "from emissions_data\n",
        "ORDER BY total_emissions DESC\n",
        "LIMIT 10;\n"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
